# CORS — allowed frontend origins (JSON array)
CORS_ORIGINS=["http://localhost:5173"]

# Detection backend (opencv, retinaface, mtcnn, ssd)
DETECTOR_BACKEND=opencv
TARGET_FRAME_WIDTH=480

# Security
AUTH_ENABLED=false
API_SECRET_KEY=
RATE_LIMIT_FPS=5.0
RATE_LIMIT_BURST=10
MAX_FRAME_SIZE=500000
MAX_WS_CONNECTIONS=10

# Logging (INFO, DEBUG, WARNING, ERROR)
LOG_LEVEL=INFO
LOG_FORMAT=json
